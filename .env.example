OPENAI_API_KEY=sk-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Gmail SMTP (delivery node — sends the complaint notice email) — optional,
# feature disables gracefully if unset ("Email credentials not configured").
# GMAIL_ADDRESS is the Gmail account the notice is sent FROM.
# GMAIL_APP_PASSWORD is a Gmail App Password (NOT your normal Gmail password —
# generate one at https://myaccount.google.com/apppasswords, requires 2FA on).
GMAIL_ADDRESS=youraccount@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Forum location lookup uses OpenStreetMap Nominatim — free, no API key required.

# Tavily (company contact search via official remote MCP server) — free tier, no card
# Get your key at https://tavily.com
TAVILY_API_KEY=tvly-...

# --- FastAPI backend (security + deployment) ---
# Comma-separated origins allowed to call the API (your Streamlit frontend's URL).
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Optional shared secret the frontend must send as the X-API-Key header.
# Leave blank in local dev; set a real random value in production and put the
# same value in frontend/.env's BACKEND_API_KEY.
BACKEND_API_KEY=

# Per-IP rate limit (single-process default — see backend/security.py for
# notes on scaling this to multiple workers).
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
