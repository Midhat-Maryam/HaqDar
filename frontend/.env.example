# URL where the FastAPI backend is reachable from the frontend.
# Local dev (both running on your machine): http://localhost:8000
# Docker Compose (services on the same network): http://backend:8000
BACKEND_URL=http://localhost:8000

# Only needed if the backend has BACKEND_API_KEY set (see haqdar/.env.example) —
# must match exactly. Leave blank otherwise.
BACKEND_API_KEY=

REQUEST_TIMEOUT_SECONDS=60
